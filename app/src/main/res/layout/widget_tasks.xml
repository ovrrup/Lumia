<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent">

    <!-- Background Layer -->
    <ImageView
        android:id="@+id/widget_bg_image"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/widget_bg_base"
        android:scaleType="fitXY" />

    <!-- Content Layer -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/widget_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Active Tasks"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/widget_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Upcoming priorities"
            android:textColor="#94A3B8"
            android:textSize="11sp"
            android:layout_marginTop="2dp"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:id="@+id/widget_items_container"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/widget_no_tasks"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="All caught up! No active tasks."
                android:textColor="#E2E8F0"
                android:textSize="13sp"
                android:gravity="center"
                android:visibility="gone" />

            <TextView
                android:id="@+id/widget_task_item_1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#F1F5F9"
                android:textSize="12sp"
                android:layout_marginTop="2dp"
                android:ellipsize="end"
                android:singleLine="true"
                android:visibility="gone" />

            <TextView
                android:id="@+id/widget_task_item_2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#F1F5F9"
                android:textSize="12sp"
                android:layout_marginTop="6dp"
                android:ellipsize="end"
                android:singleLine="true"
                android:visibility="gone" />

            <TextView
                android:id="@+id/widget_task_item_3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#F1F5F9"
                android:textSize="12sp"
                android:layout_marginTop="6dp"
                android:ellipsize="end"
                android:singleLine="true"
                android:visibility="gone" />
                
        </LinearLayout>
    </LinearLayout>
</RelativeLayout>
