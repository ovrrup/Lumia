<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@drawable/widget_background">

    <TextView
        android:id="@+id/widget_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Today's Classes"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/widget_subtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Timetable schedule"
        android:textColor="#94A3B8"
        android:textSize="11sp"
        android:layout_marginTop="2dp"
        android:layout_marginBottom="8dp" />

    <LinearLayout
        android:id="@+id/widget_items_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/widget_no_classes"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:text="Chill Day! No classes scheduled."
            android:textColor="#E2E8F0"
            android:textSize="13sp"
            android:gravity="center"
            android:visibility="gone" />

        <TextView
            android:id="@+id/widget_item_1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#F1F5F9"
            android:textSize="12sp"
            android:layout_marginTop="2dp"
            android:ellipsize="end"
            android:singleLine="true"
            android:visibility="gone" />

        <TextView
            android:id="@+id/widget_item_2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#F1F5F9"
            android:textSize="12sp"
            android:layout_marginTop="6dp"
            android:ellipsize="end"
            android:singleLine="true"
            android:visibility="gone" />

        <TextView
            android:id="@+id/widget_item_3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#F1F5F9"
            android:textSize="12sp"
            android:layout_marginTop="6dp"
            android:ellipsize="end"
            android:singleLine="true"
            android:visibility="gone" />
            
    </LinearLayout>
</LinearLayout>
